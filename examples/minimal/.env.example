# Optional overrides for native uvicorn or custom compose env_file.
# Copy: cp .env.example .env
# Docker compose in this folder uses inline env by default (fixture config + ACP_DATA_DIR volume).

# Runtime paths (see ARCHITECTURE.md)
# ACP_CONFIG_DIR=tests/fixtures/config
# ACP_DATA_DIR=/data/acp

# Optional backends
# ACP_REDIS_URL=redis://localhost:6379
# ACP_JWKS_URL=https://your-idp/.well-known/jwks.json
# ACP_MCP_GIT_URL=http://localhost:3000
# ACP_API_URL=http://127.0.0.1:8000
