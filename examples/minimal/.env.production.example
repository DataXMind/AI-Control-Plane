# Production compose env — copy before first deploy:
#   cp .env.production.example .env.production
#   chmod 600 .env.production
#
# Used with:
#   docker compose -f docker-compose.yml -f docker-compose.production.yml \
#     --env-file .env.production up -d --build

# Host bind mount for policy YAML (absolute path recommended on VPS)
ACP_HOST_CONFIG_DIR=./production-config

# Published port (use reverse proxy in real prod; bind 127.0.0.1 if proxy terminates TLS)
ACP_HOST_PORT=8000

# Redis — CHANGE before deploy (quota + action registry persistence)
REDIS_PASSWORD=changeme-generate-strong-secret

# Optional identity (recommended when agents are not fully trusted — THREAT_MODEL S-1)
# ACP_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json

# Optional MCP git facade (experimental — label issues [mcp-unverified])
# ACP_MCP_GIT_URL=http://host.docker.internal:3000
