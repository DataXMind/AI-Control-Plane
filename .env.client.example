# Client-only environment — copy to .env or export in your shell.
# CONNECT door: ACP is already running somewhere else.
# See docs/QUICKSTART.md §2
#
# Replace YOUR_HOST below (no angle brackets):
#   127.0.0.1:8000     — same machine as ACP
#   192.168.1.10:8000  — LAN IP of machine running ACP

ACP_API_URL=http://127.0.0.1:8000

# Do NOT set on client machines (API host only):
# ACP_CONFIG_DIR=
# ACP_DATA_DIR=
# ACP_REDIS_URL=
