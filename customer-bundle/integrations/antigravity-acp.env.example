# Per-machine ACP identity — copy to ~/.acp-agent.env (not committed)
# MUST use export — child processes (python3, run_tool_guarded) do not see bare assignments.
export ACP_API_URL=http://100.94.21.33:8000
export ACP_PROJECT_ID=rust-gateway
export ACP_TIMEOUT_S=3.0

# MSI Antigravity (infra):
export ACP_AGENT_ID=agent1
export ACP_ROLE=infra

# Mac IDE (backend) — comment MSI lines above, uncomment below:
# export ACP_AGENT_ID=agent2
# export ACP_ROLE=backend

# Enable zsh auto-guard for kubectl/git/cargo (default on when sourced):
# ACP_SHELL_GUARD=1
